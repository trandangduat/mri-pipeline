+        if identity:
+            self.progress_context_by_job.pop(identity, None)
+        was_active = self.active_progress_context_id == context_id
+        try:
+            self.gui.notebook.forget(context["tab"])
+        except Exception:
+            pass
+        try:
+            context["tab"].destroy()
+        except Exception:
+            pass
+        self.progress_contexts.pop(context_id, None)
+        if was_active:
