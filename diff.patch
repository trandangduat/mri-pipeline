+            "total": total,
+            "status": "Pending",
+            "percent": 0.0,
+            "logs": [],
+            "cpu": [],
+            "ram": [],
+            "gpu": [],
+            "container": "n/a",
+            "stage": "Queued",
+            "stage_detail": "Waiting to start",
+            "steps": {stage: self._make_step_state(stage) for stage in STAGE_ORDER},
